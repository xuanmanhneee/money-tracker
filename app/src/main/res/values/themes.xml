<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MoneyTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/bg_white</item>
    </style>

    <style name="Theme.MoneyTracker" parent="Base.Theme.MoneyTracker" />
    
    <!-- Card Style -->
    <style name="MoneyTracker.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_secondary</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <!-- Button Style -->
    <style name="MoneyTracker.Button" parent="Widget.Material3.Button">
        <item name="backgroundColor">@color/bg_button</item>
    </style>
</resources>
