<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <!-- TOP BAR -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:id="@+id/ivBackDetail"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Chi tiết giao dịch"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />
            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:src="@drawable/ic_add"
                android:rotation="45"
                app:tint="@color/text_primary"
                android:contentDescription="Xóa" />
        </FrameLayout>

        <!-- SỐ TIỀN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="16dp"
            android:background="@color/surface_card"
            android:padding="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VND"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />
            <EditText
                android:id="@+id/etDetailAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="36sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:backgroundTint="@android:color/transparent"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/tvDetailWorkHours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- CHỌN NHÓM -->
        <LinearLayout
            android:id="@+id/btnDetailSelectCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_clickable_row"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_category"
                app:tint="@color/bg_button" />
            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn nhóm"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- PHƯƠNG THỨC THANH TOÁN -->
        <LinearLayout
            android:id="@+id/btnDetailSelectPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_clickable_row"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_money"
                app:tint="@color/bg_button" />
            <TextView
                android:id="@+id/tvDetailPaymentMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiền mặt"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- GHI CHÚ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_surface_input">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_add"
                app:tint="@color/bg_button" />
            <EditText
                android:id="@+id/etDetailNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ghi chú"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:backgroundTint="@android:color/transparent"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- NGÀY THÁNG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="10dp"
            android:background="@color/surface_card_alt">

            <ImageButton
                android:id="@+id/btnDetailPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@drawable/bg_filter_button"
                app:tint="@color/bg_button"/>

            <TextView
                android:id="@+id/txtDetailDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>

            <ImageButton
                android:id="@+id/btnDetailNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_next"
                android:background="@drawable/bg_filter_button"
                app:tint="@color/bg_button"/>

        </LinearLayout>

        <!-- NÚT LƯU -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveTransaction"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="LƯU"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_button"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/bg_button" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
